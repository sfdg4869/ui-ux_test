PLAYWRIGHT_BASE_URL=https://10.10.34.114
# Stable default for shared-account UI regression. Increase only if the environment tolerates parallel sessions.
PLAYWRIGHT_WORKERS=1
# Optional: artifact policy for HTML report attachments.
# For passed tests, use `on` if you want screenshots/videos attached too.
PLAYWRIGHT_TRACE_MODE=retain-on-failure
PLAYWRIGHT_SCREENSHOT_MODE=only-on-failure
PLAYWRIGHT_VIDEO_MODE=off
EXEMBLE_USERNAME=
EXEMBLE_PASSWORD=
# If the value contains #, spaces, or other special characters, wrap it in quotes.
# Example: EXEMBLE_PASSWORD="password12#"
# Optional: previously recorded authenticated storage state
EXEMBLE_STORAGE_STATE=
# Optional: explicit role-separated credentials for authorization comparison.
# If EXEMBLE_ADMIN_* is omitted, the harness falls back to EXEMBLE_USERNAME / EXEMBLE_PASSWORD for the admin profile.
EXEMBLE_ADMIN_USERNAME=
EXEMBLE_ADMIN_PASSWORD=
EXEMBLE_ADMIN_STORAGE_STATE=
EXEMBLE_USER_USERNAME=
EXEMBLE_USER_PASSWORD=
EXEMBLE_USER_STORAGE_STATE=
EXEMBLE_MUTATION_USERNAME=
EXEMBLE_MUTATION_PASSWORD=
EXEMBLE_MUTATION_STORAGE_STATE=
# Optional: comma-separated authorization expectations for admin/user comparison.
EXEMBLE_AUTHZ_ADMIN_VISIBLE_MENUS=권한,로그
EXEMBLE_AUTHZ_USER_HIDDEN_MENUS=권한,로그
EXEMBLE_AUTHZ_ADMIN_ALLOWED_ROUTES=/permission/account,/permission/org,/permission/vector-database-access,/log
EXEMBLE_AUTHZ_USER_BLOCKED_ROUTES=/permission/account,/permission/org,/permission/vector-database-access,/log
EXEMBLE_AUTHZ_DENIAL_MARKERS=권한이 없습니다,접근 권한이 없습니다,Unauthorized,Forbidden,403
# Safety: keep this disabled unless you are using a disposable test account for write flows.
EXEMBLE_ALLOW_MUTATION_TESTS=0
# Required only when EXEMBLE_ALLOW_MUTATION_TESTS=1. Use a dedicated disposable account that is separate from the shared admin/user accounts.
# Optional: root folder containing test_99MB / test_100MB / test_101MB subfolders.
EXEMBLE_UPLOAD_SIZE_FIXTURE_ROOT=
# Optional: activate upload limit cases with local sample data
EXEMBLE_UPLOAD_LIMIT_11_FILES_DIR=
EXEMBLE_UPLOAD_LIMIT_100MB_FILE=
# Optional: activate upload format acceptance cases
EXEMBLE_UPLOAD_SAMPLE_TEXT_FILE=
EXEMBLE_UPLOAD_SAMPLE_IMAGE_FILE=
EXEMBLE_UPLOAD_SAMPLE_DOCUMENT_FILE=
EXEMBLE_UPLOAD_SAMPLE_MEDIA_FILE=
